{
  "name": "shaka-visreg",
  "version": "0.0.5",
  "description": "Shaka-visreg: Catch CSS curveballs.",
  "homepage": "https://github.com/shakacode/shakaperf#readme",
  "bin": "./dist/cli/index.js",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-assets.mjs",
    "typecheck": "tsc --noEmit",
    "test": "yarn jest",
    "build-compare": "node -e \"const fs=require('fs');fs.copyFileSync(require.resolve('diverged/src/diverged.js'),'./compare/output/diverged.js');fs.copyFileSync(require.resolve('diff/dist/diff.js'),'./compare/output/diff.js')\" && webpack --config ./compare/webpack.config.cjs && node ./compare/build-html.mjs",
    "dev-compare": "webpack-dev-server --config ./compare/webpack.config.cjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/shakacode/shakaperf.git"
  },
  "author": "ShakaCode",
  "license": "MIT",
  "main": "./dist/core/runner.js",
  "types": "./dist/core/runner.d.ts",
  "exports": {
    ".": {
      "types": "./dist/core/runner.d.ts",
      "default": "./dist/core/runner.js"
    },
    "./core/types": {
      "types": "./dist/core/types.d.ts",
      "default": "./dist/core/types.js"
    },
    "./helpers": {
      "types": "./dist/capture/helpers/index.d.ts",
      "default": "./dist/capture/helpers/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "helpers": ["dist/capture/helpers/index.d.ts"],
      "core/types": ["dist/core/types.d.ts"]
    }
  },
  "devDependencies": {
    "@babel/core": "^7.23.6",
    "@babel/preset-env": "^7.23.6",
    "@babel/preset-react": "^7.23.3",
    "@jest/globals": "^30.0.0",
    "@types/fs-extra": "^11.0.0",
    "@types/jest": "^29.5.11",
    "@types/junit-report-builder": "^3.0.0",
    "@types/lodash": "^4.17.0",
    "@types/node": "^22.0.0",
    "@types/object-hash": "^3.0.0",
    "@types/pixelmatch": "^5.2.0",
    "@types/pngjs": "^6.0.0",
    "@types/temp": "^0.9.0",
    "assert": "^2.1.0",
    "babel-loader": "^9.1.3",
    "backstop-twentytwenty": "^1.1.0",
    "diff": "^3.5.0",
    "file-loader": "^6.2.0",
    "jest": "^30.0.0",
    "jest-junit": "^16.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-modal": "^3.16.1",
    "react-redux": "^9.0.4",
    "react-sticky": "^6.0.3",
    "react-toggle-button": "^2.2.0",
    "react-visibility-sensor": "^5.1.1",
    "redux": "^5.0.0",
    "styled-components": "^6.1.2",
    "ts-jest": "^29.2.0",
    "typescript": "^5.9.0",
    "url-loader": "^4.1.1",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  },
  "dependencies": {
    "@mirzazeyrek/node-resemble-js": "^1.2.1",
    "chalk": "^4.1.2",
    "commander": "^13.1.0",
    "diverged": "^0.1.3",
    "fs-extra": "^11.2.0",
    "jump.js": "^1.0.2",
    "junit-report-builder": "^3.1.0",
    "lodash": "^4.17.21",
    "object-hash": "3.0.0",
    "opn": "^6.0.0",
    "os": "^0.1.2",
    "p-map": "^4.0.0",
    "path": "^0.12.7",
    "pixelmatch": "^5.3.0",
    "playwright": "^1.40.1",
    "pngjs": "^7.0.0",
    "portfinder": "^1.0.32",
    "shaka-shared": "workspace:^",
    "temp": "^0.9.4",
    "tsx": "^4.7.0"
  }
}
