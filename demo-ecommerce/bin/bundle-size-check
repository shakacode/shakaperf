#!/usr/bin/env node

/**
 * Demo-Ecommerce Bundle Size Check CLI
 *
 * Thin wrapper that calls the shaka-bundle-size CLI for each app.
 *
 * Usage:
 *   bin/bundle-size-check                  # Check both apps
 *   bin/bundle-size-check --consumer-only  # Check only consumer
 *   bin/bundle-size-check --update         # Update baselines
 *   bin/bundle-size-check --download       # Download baseline from storage first
 *   bin/bundle-size-check --upload         # Upload baseline to storage
 */

const fs = require('fs');
const path = require('path');
const { execSync } = require('child_process');

// ============================================================================
// Constants
// ============================================================================

const BUNDLE_SIZE_DATA_LOCATION = 'tmp/bundle_size';
const BASELINE_STORAGE_DIR = 'baseline/bundle_size';
const MAIN_COMMITS_TO_CHECK = 10;

// Config files for each app
const ALL_CONFIGS = [
  'consumer.bundle-size.config.js',
  'admin.bundle-size.config.js',
];

const CONSUMER_ONLY_CONFIGS = [
  'consumer.bundle-size.config.js',
];

// ============================================================================
// CLI Helpers
// ============================================================================

function showHelp() {
  console.log(`
Usage: bin/bundle-size-check [options]

Options:
  --update          Update baseline with current build sizes
  --consumer-only   Only check consumer bundle
  --download        Download baseline from local storage (finds merge-base with main)
  --upload          Upload current baseline to local storage for current commit
  --help            Show this help message

Examples:
  bin/bundle-size-check                     # Compare current build against local baseline
  bin/bundle-size-check --download          # Copy baseline from storage, then compare
  bin/bundle-size-check --update            # Update local baseline with current build
  bin/bundle-size-check --upload            # Save current baseline to storage
`);
}

function parseArgs() {
  const args = process.argv.slice(2);
  return {
    update: args.includes('--update'),
    consumerOnly: args.includes('--consumer-only'),
    download: args.includes('--download'),
    upload: args.includes('--upload'),
    help: args.includes('--help') || args.includes('-h'),
  };
}

function colorize(text, color) {
  const colors = {
    red: '\x1b[31m',
    green: '\x1b[32m',
    yellow: '\x1b[33m',
    blue: '\x1b[34m',
    reset: '\x1b[0m',
  };
  return `${colors[color] || ''}${text}${colors.reset}`;
}

// ============================================================================
// Local Storage Logic
// ============================================================================

function getGitMergeBase() {
  try {
    execSync('git fetch origin main', { stdio: 'inherit' });
    const mergeBase = execSync('git merge-base origin/main HEAD', { encoding: 'utf8' }).trim();
    return mergeBase;
  } catch (error) {
    console.error(colorize('Failed to get merge base with main', 'red'));
    throw error;
  }
}

function getRecentMainCommits(mergeBase, count) {
  const output = execSync(`git log -${count} --pretty=format:"%H" ${mergeBase}`, { encoding: 'utf8' });
  return output.split('\n').filter(Boolean);
}

function getCurrentCommit() {
  return execSync('git rev-parse HEAD', { encoding: 'utf8' }).trim();
}

function getBaselinePathForCommit(commit) {
  return path.join(BASELINE_STORAGE_DIR, commit);
}

function baselineExistsForCommit(commit) {
  const baselinePath = getBaselinePathForCommit(commit);
  return fs.existsSync(baselinePath);
}

function copyDirectory(src, dest) {
  if (fs.existsSync(dest)) {
    fs.rmSync(dest, { recursive: true });
  }
  fs.cpSync(src, dest, { recursive: true });
}

function downloadBaseline() {
  console.log(colorize('Downloading baseline from local storage...', 'blue'));

  const mergeBase = getGitMergeBase();
  const commits = getRecentMainCommits(mergeBase, MAIN_COMMITS_TO_CHECK);

  for (const commit of commits) {
    const baselinePath = getBaselinePathForCommit(commit);
    console.log(`Checking for baseline at ${baselinePath}...`);

    if (baselineExistsForCommit(commit)) {
      console.log(colorize(`Found baseline for commit ${commit.substring(0, 7)}`, 'green'));

      // Copy baseline to working location
      copyDirectory(baselinePath, BUNDLE_SIZE_DATA_LOCATION);
      console.log(colorize(`Copied to ${BUNDLE_SIZE_DATA_LOCATION}`, 'green'));

      return commit;
    } else {
      console.log(colorize(`Baseline not found for commit ${commit.substring(0, 7)}. Trying older commits...`, 'yellow'));
    }
  }

  throw new Error(`No baseline found for any of the last ${MAIN_COMMITS_TO_CHECK} main commits`);
}

function uploadBaseline() {
  console.log(colorize('Uploading baseline to local storage...', 'blue'));

  if (!fs.existsSync(BUNDLE_SIZE_DATA_LOCATION)) {
    throw new Error(`No baseline data found at ${BUNDLE_SIZE_DATA_LOCATION}. Run --update first.`);
  }

  const commit = getCurrentCommit();
  const baselinePath = getBaselinePathForCommit(commit);

  // Ensure storage directory exists
  fs.mkdirSync(BASELINE_STORAGE_DIR, { recursive: true });

  // Copy current baseline to storage
  copyDirectory(BUNDLE_SIZE_DATA_LOCATION, baselinePath);
  console.log(colorize(`Uploaded baseline for commit ${commit.substring(0, 7)} to ${baselinePath}`, 'green'));

  return commit;
}

// ============================================================================
// Main Entry Point
// ============================================================================

function main() {
  const args = parseArgs();

  if (args.help) {
    showHelp();
    process.exit(0);
  }

  if (args.download && args.update) {
    console.error(colorize('Cannot use --download and --update together', 'red'));
    process.exit(1);
  }

  // Download baseline from local storage if requested
  if (args.download) {
    try {
      downloadBaseline();
    } catch (error) {
      console.error(colorize(`Failed to download baseline: ${error.message}`, 'red'));
      process.exit(1);
    }
  }

  // Upload baseline to local storage if requested
  if (args.upload) {
    try {
      uploadBaseline();
      process.exit(0);
    } catch (error) {
      console.error(colorize(`Failed to upload baseline: ${error.message}`, 'red'));
      process.exit(1);
    }
  }

  // Run bundle size checks for each config
  const configs = args.consumerOnly ? CONSUMER_ONLY_CONFIGS : ALL_CONFIGS;
  let failed = false;

  for (const config of configs) {
    console.log(colorize(`\nChecking ${config}...`, 'blue'));

    try {
      const flags = args.update ? '--update' : '';
      const cmd = `yarn shaka-bundle-size --config ${config} ${flags}`.trim();
      execSync(cmd, { stdio: 'inherit' });
    } catch (error) {
      // Command failed (non-zero exit code)
      failed = true;
    }
  }

  process.exit(failed ? 1 : 0);
}

main();
