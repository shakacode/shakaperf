{
  "packageManager": "yarn@4.12.0",
  "name": "demo-ecommerce",
  "private": true,
  "version": "0.1.0",
  "browserslist": [
    "defaults"
  ],
  "scripts": {
    "build": "bin/shakapacker",
    "build:prod": "NODE_OPTIONS='--max-old-space-size=4096' NODE_ENV=production yarn webpack --config config/webpack/webpack.config.js",
    "build:prod:stats": "CLIENT_BUNDLE_ONLY=true yarn build:prod --json public/packs/${BUNDLE_NAME:-app}-webpack-stats.json",
    "build:prod:consumer": "BUNDLE_NAME=consumer yarn build:prod:stats",
    "build:prod:admin": "BUNDLE_NAME=admin ADMIN_BUNDLE_ONLY=true yarn build:prod:stats",
    "build:prod:all:stats": "yarn build:prod:consumer && yarn build:prod:admin",
    "build:analyze": "ANALYZE=true bin/shakapacker",
    "test:bundle-size": "shaka-bundle-size"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@loadable/component": "^5.16.7",
    "@loadable/server": "^5.16.7",
    "@mui/icons-material": "^7.3.7",
    "@mui/material": "^7.3.7",
    "@swc/core": "^1.15.8",
    "compression-webpack-plugin": "^11.1.0",
    "css-loader": "7.1.2",
    "css-minimizer-webpack-plugin": "7.0.4",
    "mini-css-extract-plugin": "2.9.4",
    "prop-types": "15.8.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-on-rails": "16.2.0-rc.0",
    "react-router-dom": "^7.12.0",
    "sass-loader": "^16.0.6",
    "shakapacker": "9.5.0",
    "style-loader": "4.0.0",
    "swc-loader": "^0.2.6",
    "terser-webpack-plugin": "^5.3.16",
    "webpack": "^5.104.1",
    "webpack-assets-manifest": "^6.5.0",
    "webpack-bundle-analyzer": "^5.1.1",
    "webpack-cli": "^6.0.1",
    "webpack-merge": "^6.0.1",
    "webpack-subresource-integrity": "^5.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@loadable/babel-plugin": "^5.16.1",
    "@loadable/webpack-plugin": "^5.15.2",
    "@pmmmwh/react-refresh-webpack-plugin": "0.6.2",
    "@types/babel__core": "^7",
    "@types/loadable__component": "^5.13.10",
    "@types/loadable__server": "^5.12.11",
    "@types/loadable__webpack-plugin": "^5",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "react-refresh": "0.18.0",
    "shaka-bench": "workspace:*",
    "shaka-bundle-size": "workspace:*",
    "shaka-twin-server": "workspace:*",
    "shaka-visreg": "workspace:*",
    "typescript": "^5.9.3",
    "webpack-dev-server": "^5.2.2"
  }
}
