# NOTE: all cache keys are prefixed by a version number just in case we need to manually bust in
# strange situations.
# NOTE: to update Ruby, node, yarn, chrome versions
#   * Run the script script/docker/build.ci. This file uses the node and yarn versions in the package.json.
#   * Ensure this file is updated with the right dockerfile.
version: 2.1

aliases:
  - &restore-yarn-cache
    name: Restore cached root node_modules
    keys:
      - ruby-3.4.2--node-20.17.0--yarn-4--v1--yarn-cache-{{ checksum "yarn.lock" }}
  - &restore-seeds-file-cache
    name: Restore cached seeds
    keys:
      - v2-seeds-cache-{{ checksum ".seeds_version" }}
  - &restore-cypress-cache
    name: Restore cached cypress folder
    keys:
      - cypress--v13-cache-{{ checksum "yarn.lock" }}
  - &restore-gem-cache
    name: Restore cached Ruby Gems
    keys:
      - ruby-3.4.2--node-20.17.0--yarn-4--gem-cache-2-{{ checksum "Gemfile.lock" }}
  - &restore-production-gem-cache
    name: Restore production cached Ruby Gems
    keys:
      - ruby-3.4.2--node-20.17.0--yarn-4--gem-cache-2-production-{{ checksum "Gemfile.lock" }}
  - &restore-webpack-cache
    name: Restore cached webpack assets
    keys:
      - ruby-3.4.2--node-20.17.0--yarn-4--v1--webpack-cache-{{ checksum "yarn.lock" }}-{{ checksum "config/webpack/webpack.config.js" }}-{{ .Revision }}
  - &install-ruby-gems
    name: Install Ruby Gems
    command: |
      gem install bundler -v 2.6.2
      bin/bundle check --path=vendor/bundle || bin/bundle install --path=vendor/bundle --jobs=4 --retry=3
  - &add-gem-executables-to-path
    name: Add gem executables to PATH
    command: |
      echo -e "export PATH=vendor/bundle/ruby/3.2.0/bin:$PATH" >> $BASH_ENV
      source $BASH_ENV
  - &enable-corepack
    name: Enable corepack for Yarn 4
    command: corepack enable && corepack install
  - &install-node-packages
    name: Yarn install deps
    command: yarn install --immutable
  - &wait-for-mysql-container
    name: Wait for MySQL Container
    command: dockerize -wait tcp://localhost:3306 -timeout 1m
  - &make-rspec-dir
    name: Make rspec dir to hold results
    command: mkdir rspec
  - &add-node-module-path
    name: Add node_modules to PATH
    command: |
      echo -e "export PATH=$HOME/project/node_modules/.bin:$PATH " >> $BASH_ENV
      source $BASH_ENV
  - &install-control-plane-tools
    name: Install Control Plane tools
    command: |
      sudo npm install -g @controlplane/cli@3.6.1 && cpln --version
      gem install cpflow -v 4.1.1 && cpflow --version
  - &login-control-plane-tools-staging
    name: Setup Control Plane tools for staging
    command: |
      cpln profile create default --token $CPLN_TOKEN_STAGING --org $CPLN_ORG_STAGING --gvc $APP_NAME_STAGING
      cpln image docker-login
  - &authenticate-control-plane-tools-production
    name: Authenticate Control Plane tools for production
    command: |
      cpln profile create default --token $CPLN_TOKEN_PRODUCTION --org $CPLN_ORG_PRODUCTION --gvc $APP_NAME_PRODUCTION
      cpln image docker-login
  - &warm-up-staging-persephone
    name: Warm up persephone
    command: .circleci/persephone_warmer.sh $PRINTIVITY_GLOBAL_ENDPOINTS_PERSEPHONE

commands:
  common_cypress_steps:
    parameters:
      smarty-api-tests:
        type: boolean
        default: false
    steps:
      - checkout
      - restore_cache: *restore-gem-cache
      - restore_cache: *restore-yarn-cache
      - restore_cache: *restore-seeds-file-cache
      - restore_cache: *restore-cypress-cache
      - restore_cache: *restore-webpack-cache
      - run: *enable-corepack
      - run: *add-node-module-path
      - run: *install-ruby-gems
      - run: *wait-for-mysql-container
      - run:
          name: Install Cypress if not cached
          command: |
            if [ ! -d ~/.cache/Cypress ]; then
              echo "Cypress binary not found, installing Cypress..."
              ./node_modules/.bin/cypress install
            else
              echo "Cypress binary found, skipping installation."
            fi
      - save_cache:
          name: Save ~/.cache/Cypress to cache
          key: cypress--v13-cache-{{ checksum "yarn.lock" }}
          paths:
            - ~/.cache
      - run: CONFIGURING_DATABASE=true bundle exec rake db:create
      - run: CONFIGURING_DATABASE=true bundle exec rake db:schema:load
      - run:
          name: Copy cached seed if it exists otherwise do nothing
          command: |
            if [ -f "seeds_cache/seeds_sql_$(cat .seeds_version).tgz" ]; then
              echo "File exists, copying cached seed to db/seeds/"
              cp "seeds_cache/seeds_sql_$(cat .seeds_version).tgz" "db/seeds/seeds_sql_$(cat .seeds_version).tgz"
            fi
      - run: RAILS_ENV=test bundle exec rake db:seed # seed the database. this downloads the seed if it is not cached
      - run: mkdir -p seeds_cache && cp "db/seeds/seeds_sql_$(cat .seeds_version).tgz" seeds_cache/
      - save_cache:
          name: Save seeds archive to cache
          key: v2-seeds-cache-{{ checksum ".seeds_version" }}
          paths:
            - seeds_cache
      - run: RAILS_ENV=test bundle exec rake flush:setup_bogus_gateway
      - run:
          name: install mailcatcher
          command: |
            gem install mailcatcher
      - run:
          name: Start Rails server
          command: |
            source $BASH_ENV
            CYPRESS=true bundle exec rails s -b 0.0.0.0 -p 3764
          background: true
      - run:
          name: Start node renderer
          command: node node-renderer.js -p 3800
          background: true
      - run:
          name: Start order node broadcast worker
          command: |
            source $BASH_ENV
            bundle exec rake jobs:work QUEUE=order_node_broadcast ORDER_NODE_WORKLOAD=true
          background: true
      - run:
          name: Wait for Rails server
          no_output_timeout: 5m
          command: sleep 25s
          # dockerize wait returns 500 because cypress test will initialize db in hook
          # command: dockerize -wait http://localhost:3764 -timeout 30s
      - run:
          name: Make cypress dir to hold results
          command: mkdir -p test_results/cypress
      - run: *warm-up-staging-persephone
      - run:
          name: run mailcatcher
          background: true
          command: |
            # Start mailcatcher
            mailcatcher --http-ip 0.0.0.0 &

            # Wait for mailcatcher to start
            sleep 10
      - when:
          condition: << parameters.smarty-api-tests >>
          steps:
            - run:
                name: Cypress Smarty Tests
                no_output_timeout: 10m
                command: |
                  export DISPLAY=:99
                  yarn cypress run --browser chrome --e2e --spec "$(circleci tests glob "./cypress/e2e/smarty/*.cy.ts" | circleci tests split --split-by=timings | paste -sd "," -)" --reporter cypress-circleci-reporter
      - unless:
          condition: << parameters.smarty-api-tests >>
          steps:
            - run:
                name: Cypress App,Yvantage Tests
                no_output_timeout: 10m
                command: |
                  export DISPLAY=:99
                  yarn cypress run --browser chrome --e2e --spec "$(circleci tests glob "./cypress/e2e/Yvantage/*.cy.ts" "./cypress/e2e/app/*.cy.ts" | circleci tests split --split-by=timings | paste -sd "," -)" --reporter cypress-circleci-reporter
      - store_test_results:
          path: test_results/cypress
      - store_artifacts:
          path: test_results/cypress
      - store_artifacts:
          path: tmp/cypress
      - store_artifacts:
          path: ~/project/cypress/screenshots
      - store_artifacts:
          path: log/cypress/test.log

defaults: &defaults
  environment:
    RAILS_ENV: test
    RACK_ENV: test
    NODE_ENV: test

rspec-defaults: &rspec-defaults
  <<: *defaults
  docker:
    - image: ekrueger88/printivity-ci:ruby-3.4.2--node-20.17.0
      environment:
        DISABLE_SPRING: true
        REDIS_URL: redis://redis:6379/0
    - image: redis:7.4.4-alpine
      name: redis
    - image: mysql:8.0.36
      command: --default-authentication-plugin=mysql_native_password
      environment:
        MYSQL_ALLOW_EMPTY_PASSWORD: yes
        MYSQL_ROOT_PASSWORD: ''
        MYSQL_DATABASE: printivity_test

cpln-defaults: &cpln-defaults
  resource_class: large
  # this node version is for for controlplane cli, it may be different from app's used node and ruby versions
  docker:
    - image: cimg/ruby:3.1-node
  environment:
    CPLN_ORG_STAGING: printivity-staging
    CPLN_ORG_PRODUCTION: printivity
    REVIEW_APP_NAME_PREFIX: printivity-review
    REVIEW_APP_NAME_STORYBOOK_PREFIX: printivity-storybook-review
    APP_NAME_STORYBOOK: printivity-storybook
    APP_NAME_STAGING: printivity-staging
    APP_NAME_PRODUCTION: printivity-production
    IMAGE_BUILD_TIMEOUT: 1800s # 25 min, or ~3x current build times
    DATABASE_TASKS_TIMEOUT: 1800s # 25 min, or ~3x current create and seed times
    DEPLOY_IMAGE_TIMEOUT: 60s # 1 min, or ~10x current deploy

machine-defaults: &machine-defaults
  machine:
    image: ubuntu-2204:2023.10.1
  resource_class: large

jobs:
  install-node-packages:
    <<: *defaults
    docker:
      - image: ekrueger88/printivity-ci:ruby-3.4.2--node-20.17.0
    steps:
      - checkout
      - restore_cache: *restore-yarn-cache
      - run: node -v
      - run: *enable-corepack
      - run: *install-node-packages
      - save_cache:
          name: Save node_modules to cache
          key: ruby-3.4.2--node-20.17.0--yarn-4--v1--yarn-cache-{{ checksum "yarn.lock" }}
          paths:
            - node_modules
      - save_cache:
          name: Save node_modules to cache (fallback for repo)
          key: ruby-3.4.2--node-20.17.0--yarn-4--v1--yarn-cache
          paths:
            - node_modules

  install-ruby-gems:
    <<: *defaults
    docker:
      - image: ekrueger88/printivity-ci:ruby-3.4.2--node-20.17.0
        environment:
          RAILS_ENV: test
          RACK_ENV: test
    steps:
      - checkout
      - run: *install-ruby-gems
      - save_cache:
          name: Save ruby gems to cache
          key: ruby-3.4.2--node-20.17.0--yarn-4--gem-cache-2-{{ checksum "Gemfile.lock" }}
          paths:
            - vendor/bundle

  install-production-ruby-gems:
    <<: *defaults
    docker:
      - image: ekrueger88/printivity-ci:ruby-3.4.2--node-20.17.0
        environment:
          RAILS_ENV: production
          RACK_ENV: production
          BUNDLE_WITHOUT: 'development:test'
    steps:
      - checkout
      - run: *install-ruby-gems
      - save_cache:
          name: Save ruby gems to cache
          key: ruby-3.4.2--node-20.17.0--yarn-4--gem-cache-2-production-{{ checksum "Gemfile.lock" }}
          paths:
            - vendor/bundle

  eslint:
    <<: *defaults
    docker:
      - image: ekrueger88/printivity-ci:ruby-3.4.2--node-20.17.0
    parallelism: 1
    steps:
      - checkout
      - restore_cache: *restore-yarn-cache
      - run: *enable-corepack
      - run:
          name: ESlint
          command: |
            yarn eslint --format junit --output-file ~/project/eslint/eslint.xml --quiet .
      - store_test_results:
          path: eslint
      - store_artifacts:
          path: eslint

  prettier:
    <<: *defaults
    docker:
      - image: ekrueger88/printivity-ci:ruby-3.4.2--node-20.17.0
    parallelism: 1
    steps:
      - checkout
      - restore_cache: *restore-yarn-cache
      - run: *enable-corepack
      - run:
          name: prettier
          command: |
            yarn start format.listDifferent

  scss-lint:
    <<: *defaults
    docker:
      - image: ekrueger88/printivity-ci:ruby-3.4.2--node-20.17.0
    parallelism: 1
    steps:
      - checkout
      - restore_cache: *restore-gem-cache
      - run: *install-ruby-gems
      - run:
          name: scss-lint
          command: |
            TESTFILES=$(circleci tests glob \
              "app/assets/styles/**/*.scss" \
              "client/app/**/*.scss" \
              | circleci tests split --split-by=timings --timings-type=classname)
            bin/scss-lint $TESTFILES

  rubocop:
    <<: *defaults
    docker:
      - image: ekrueger88/printivity-ci:ruby-3.4.2--node-20.17.0
    parallelism: 1
    steps:
      - checkout
      - restore_cache: *restore-gem-cache
      - run: *install-ruby-gems
      - run:
          name: rubocop
          command: |
            TESTFILES=$(circleci tests glob \
              "app/**/*.rb" \
              "config/**/*.rb" \
              "db/seeds.rb" \
              "lib/**/*.rb" \
              "lib/**/*.rake" \
              "spec/**/*.rb" \
              "config.ru" \
              "Gemfile" \
              "Rakefile" \
              | circleci tests split)
            bin/rubocop $TESTFILES

  security-checks:
    <<: *defaults
    docker:
      - image: ekrueger88/printivity-ci:ruby-3.4.2--node-20.17.0
    steps:
      - checkout
      - restore_cache: *restore-gem-cache
      - run: *install-ruby-gems
      - run:
          name: bundle-audit
          command: bundle exec bundle-audit update && bundle exec bundle-audit --ignore CVE-2018-1000544
          # FIXME: ^^^ please remove rubyzip ignore when fixed https://github.com/rubyzip/rubyzip/issues/369
      - run:
          name: brakeman
          command: bundle exec brakeman -i .brakeman.ignore -o brakeman/brakeman-report.html
      - store_artifacts:
          path: brakeman

  jest:
    <<: *defaults
    docker:
      - image: ekrueger88/printivity-ci:ruby-3.4.2--node-20.17.0
    steps:
      - checkout
      - restore_cache: *restore-yarn-cache
      - run: *enable-corepack
      - run:
          name: Jest
          environment:
            JEST_JUNIT_OUTPUT: ~/project/jest/jest.xml
          command: yarn jest --workerIdleMemoryLimit=350 --runInBand --logHeapUsage
      - store_test_results:
          path: jest
      - store_artifacts:
          path: jest

  rspec:
    <<: *rspec-defaults
    resource_class: large
    parallelism: 1
    environment:
      BASH_ENV: /home/circleci/.bashrc
      RAILS_ENV: test
      RACK_ENV: test
      NODE_ENV: test
    steps:
      - checkout
      - restore_cache: *restore-gem-cache
      - restore_cache: *restore-yarn-cache
      - run: *enable-corepack
      - run: *add-node-module-path
      - run: *install-ruby-gems
      - run: *wait-for-mysql-container
      - run: *make-rspec-dir
      - run: CONFIGURING_DATABASE=true bundle exec rake db:create
      - run: CONFIGURING_DATABASE=true bundle exec rake db:test:load_schema
      - run:
          name: Build RSpec webpack bundles if cache did not hit
          command: bin/shakapacker
      - run:
          name: Test server-bundle.js for compiling errors
          command: node public/webpack/test/server-bundle.js
      - run: *warm-up-staging-persephone
      - run:
          name: Run tests
          command: |
            source $BASH_ENV
            bin/rspec --tag ~skippable \
                      --profile 10 \
                      --format RspecJunitFormatter \
                      --out ~/rspec/rspec.xml \
                      --format progress \
                      $(circleci tests glob "spec/**/*_spec.rb" | circleci tests split --split-by=timings)
      - store_test_results:
          path: ~/rspec
      - store_artifacts:
          path: ~/rspec
      - store_artifacts:
          path: tmp/screenshots
      - store_artifacts:
          path: log/test.log

  cypress-smarty-api-tests:
    <<: *rspec-defaults
    parallelism: 1
    environment:
      BASH_ENV: /home/circleci/.bashrc
      RAILS_ENV: development
      RACK_ENV: development
      NODE_ENV: development
    circleci_ip_ranges: true # This is required to white list CircleCI IP ranges for SMARTY API key
    steps:
      - common_cypress_steps:
          smarty-api-tests: true

  cypress:
    <<: *rspec-defaults
    resource_class: large
    parallelism: 6
    environment:
      BASH_ENV: /home/circleci/.bashrc
      RAILS_ENV: development
      RACK_ENV: development
      NODE_ENV: development
    steps:
      - common_cypress_steps:
          smarty-api-tests: false

  controlplane-release-production:
    <<: *cpln-defaults
    steps:
      - checkout
      - setup_remote_docker:
          docker_layer_caching: true
      - run: *install-control-plane-tools
      - run: *authenticate-control-plane-tools-production
      - run:
          name: Containerize and push image
          command: |
            BUILDKIT_PROGRESS=plain cpflow build-image -a $APP_NAME_PRODUCTION \
              --org $CPLN_ORG_PRODUCTION \
              --commit ${CIRCLE_SHA1::7} \
              --build-arg="GIT_SHA=${CIRCLE_SHA1}" \
              --build-arg="GH_NPM_TOKEN=${GH_NPM_TOKEN}" \
              --build-arg="HONEYBADGER_API_KEY=${PRODUCTION_HONEYBADGER_API_KEY}" \
              --build-arg="HOST_URL=${PRODUCTION_APP_HOST}" \
              --build-arg="MGXCOPY_RECAPTCHA_SITE_KEY=${NON_TEST_RECAPTCHA_SITE_KEY}" \
              --build-arg="ENABLE_ANALYTICS_TRACKING=true" \
              --build-arg=GTM_ID=${PRODUCTION_GTM_ID} \
              --build-arg=QZ_PRINT_PKEY=${QZ_PRINT_PKEY} \
              --build-arg=QZ_PRINT_CERT=${QZ_PRINT_CERT}
      - run:
          name: Database tasks
          command: |
            cpflow run -a $APP_NAME_PRODUCTION --org $CPLN_ORG_PRODUCTION --image latest -- CONFIGURING_DATABASE=1 LOG_LEVEL=warn bundle exec rails db:migrate
          no_output_timeout: 1h
      - run:
          name: Warm up persephone
          command: .circleci/persephone_warmer.sh
      - run:
          name: Cache warming
          command: |
            cpflow run -a $APP_NAME_PRODUCTION --org $CPLN_ORG_PRODUCTION --image latest -- bundle exec rails mgx:context_refresh_parallel mgx:context_purge
      - run:
          name: Deploy image
          command: |
            cpflow deploy-image -a $APP_NAME_PRODUCTION --org $CPLN_ORG_PRODUCTION

  controlplane-release-staging:
    <<: *cpln-defaults
    steps:
      - checkout
      - setup_remote_docker:
          docker_layer_caching: true
      - run: *install-control-plane-tools
      - run: *login-control-plane-tools-staging
      - run:
          name: Containerize and push image
          command: |
            BUILDKIT_PROGRESS=plain cpflow build-image -a $APP_NAME_STAGING \
              --commit ${CIRCLE_SHA1::7} \
              --build-arg="GIT_SHA=${CIRCLE_SHA1}" \
              --build-arg="GH_NPM_TOKEN=${GH_NPM_TOKEN}" \
              --build-arg="HONEYBADGER_API_KEY=${STAGING_HONEYBADGER_API_KEY}" \
              --build-arg="HOST_URL=${STAGING_APP_HOST}" \
              --build-arg="MGXCOPY_RECAPTCHA_SITE_KEY=${NON_TEST_RECAPTCHA_SITE_KEY}" \
              --build-arg="QZ_PRINT_PKEY=${QZ_PRINT_PKEY}" \
              --build-arg="QZ_PRINT_CERT=${QZ_PRINT_CERT}"
      - run:
          name: Database tasks
          command: |
            cpflow run -a $APP_NAME_STAGING --image latest -- CONFIGURING_DATABASE=1 LOG_LEVEL=warn bundle exec rails db:migrate
          no_output_timeout: 1h
      - run: *warm-up-staging-persephone
      - run:
          name: Cache warming
          command: |
            cpflow run -a $APP_NAME_STAGING --image latest -- bundle exec rails mgx:context_refresh_parallel mgx:context_purge
      - run:
          name: Deploy image
          command: |
            cpflow deploy-image -a $APP_NAME_STAGING
  controlplane-storybook-staging:
    <<: *cpln-defaults
    steps:
      - checkout
      - setup_remote_docker:
          docker_layer_caching: true
      - run: *install-control-plane-tools
      - run: *login-control-plane-tools-staging
      - run:
          name: Provision Storybook app if needed
          command: |
            if ! cpflow exists -a $APP_NAME_STORYBOOK; then
              cpflow setup-app -a $APP_NAME_STORYBOOK --skip-secret-access-binding
              echo "Enabling storybook to access staging app secrets"
              cpln policy add-binding $APP_NAME_STAGING-secrets-policy \
                    --permission reveal \
                    --identity /org/$CPLN_ORG_STAGING/gvc/$APP_NAME/identity/$APP_NAME_STORYBOOK-identity
              echo "export NEW_APP=true" >> $BASH_ENV
            fi
      - run:
          name: Containerize and push image
          command: |
            BUILDKIT_PROGRESS=plain cpflow build-image -a $APP_NAME_STORYBOOK --commit ${CIRCLE_SHA1::7} --build-arg="GH_NPM_TOKEN=${GH_NPM_TOKEN}"
      - run:
          name: Deploy image
          command: |
            cpflow deploy-image -a $APP_NAME_STORYBOOK

  build-review-app:
    <<: *cpln-defaults
    steps:
      - checkout
      - setup_remote_docker:
          docker_layer_caching: true
      - run:
          name: Setup environment
          command: |
            PR_NUM=$(echo $CIRCLE_PULL_REQUEST | grep -Eo '[0-9]+$')
            echo "export APP_NAME=$REVIEW_APP_NAME_PREFIX-$PR_NUM" >> $BASH_ENV
      - run: *install-control-plane-tools
      - run: *login-control-plane-tools-staging
      - run:
          name: Provision review app if needed
          command: |
            if ! cpflow exists -a $APP_NAME; then
              cpflow setup-app -a $APP_NAME
            fi
      - run:
          name: Containerize and push image
          command: |
            timeout $IMAGE_BUILD_TIMEOUT bash -c "BUILDKIT_PROGRESS=plain cpflow build-image -a $APP_NAME \
              --commit ${CIRCLE_SHA1::7} \
              --build-arg='GIT_SHA=${CIRCLE_SHA1}' \
              --build-arg='GH_NPM_TOKEN=${GH_NPM_TOKEN}' \
              --build-arg=SKIP_SOURCE_MAPS_TO_HONEYBADGER=true \
              --build-arg=QZ_PRINT_PKEY=${QZ_PRINT_PKEY} \
              --build-arg=QZ_PRINT_CERT=${QZ_PRINT_CERT}"
      - run:
          name: Database tasks
          command: |
            timeout $DATABASE_TASKS_TIMEOUT bash -c "cpflow run -a $APP_NAME --image latest . .controlplane/prepare_review_database.sh"
          no_output_timeout: 1h
      - run: *warm-up-staging-persephone
      - run:
          name: Cache warming
          command: |
            cpflow run -a $APP_NAME --image latest -- bundle exec rails mgx:context_refresh_parallel mgx:context_purge
      - run:
          name: Deploy image
          command: |
            timeout $DEPLOY_IMAGE_TIMEOUT bash -c "cpflow deploy-image -a $APP_NAME"
  build-storybook-review-app:
    <<: *cpln-defaults
    steps:
      - checkout
      - setup_remote_docker:
          docker_layer_caching: true
      - run:
          name: Setup environment
          command: |
            PR_NUM=$(echo $CIRCLE_PULL_REQUEST | grep -Eo '[0-9]+$')
            echo "export APP_NAME=$REVIEW_APP_NAME_STORYBOOK_PREFIX-$PR_NUM" >> $BASH_ENV
      - run: *install-control-plane-tools
      - run: *login-control-plane-tools-staging
      - run:
          name: Provision Storybook app if needed
          command: |
            if ! cpflow exists -a $APP_NAME; then
              cpflow setup-app -a $APP_NAME --skip-secret-access-binding
              echo "Enabling storybook to access review app secrets"
              cpln policy add-binding $REVIEW_APP_NAME_PREFIX-secrets-policy \
                    --permission reveal \
                    --identity /org/$CPLN_ORG_STAGING/gvc/$APP_NAME/identity/$APP_NAME-identity
              echo "export NEW_APP=true" >> $BASH_ENV
            fi
      - run:
          name: Containerize and push image
          command: |
            BUILDKIT_PROGRESS=plain cpflow build-image -a $APP_NAME --commit ${CIRCLE_SHA1::7} --build-arg="GH_NPM_TOKEN=${GH_NPM_TOKEN}"
      - run:
          name: Deploy image
          command: |
            cpflow deploy-image -a $APP_NAME

  nightly-cleanup-review-apps-and-staging-org:
    <<: *cpln-defaults
    steps:
      - checkout
      - run: *install-control-plane-tools
      - run: *login-control-plane-tools-staging
      - run:
          name: Cleanup stale review apps based on open PRs
          command: |
            cpflow run -a $APP_NAME_STAGING --image latest --use-local-token -- LOG_LEVEL=warn GH_TOKEN=$GH_TOKEN bundle exec rails \
              cpflow:cleanup_review_and_storybook_apps \
              cpflow:cleanup_review_app_databases
      - run:
          name: Cleanup stale review apps based on image deployed days
          command: |
            cpflow cleanup-stale-apps -a $REVIEW_APP_NAME_PREFIX -y
      - run:
          name: Cleanup old images from review apps
          command: |
            cpflow cleanup-images -a $REVIEW_APP_NAME_PREFIX -y
      - run:
          name: Cleanup old images from the staging app
          command: |
            cpflow cleanup-images -a $APP_NAME_STAGING -y

  compile-webpack-assets:
    <<: *defaults
    docker:
      - image: ekrueger88/printivity-ci:ruby-3.4.2--node-20.17.0
    steps:
      - checkout
      - restore_cache: *restore-gem-cache
      - restore_cache: *restore-yarn-cache
      - run: *enable-corepack
      - run: *add-node-module-path
      - run: *install-ruby-gems
      - run:
          name: Clear old webpack assets
          command: |
            rm -rf public/webpack
            rm -rf public/packs
            rm -rf tmp/cache/shakapacker
      - run:
          name: Compile webpack assets for cypress (development environment)
          command: RAILS_ENV=development NODE_ENV=development CYPRESS=true bin/shakapacker
      - save_cache:
          name: Save webpack assets to cache
          key: ruby-3.4.2--node-20.17.0--yarn-4--v1--webpack-cache-{{ checksum "yarn.lock" }}-{{ checksum "config/webpack/webpack.config.js" }}-{{ .Revision }}
          paths:
            - public/webpack
            - public/packs
            - tmp/cache/shakapacker

  # Bundle size jobs require AWS credentials: AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY
  # Configure these in CircleCI project settings or via a context
  bundle-size-check:
    <<: *defaults
    docker:
      - image: ekrueger88/printivity-ci:ruby-3.4.2--node-20.17.0
    steps:
      - checkout
      - restore_cache: *restore-gem-cache
      - restore_cache: *restore-yarn-cache
      - run: *enable-corepack
      - run: *add-node-module-path
      - run: *install-ruby-gems
      - run:
          name: Build production webpack assets
          command: RAILS_ENV=production NODE_ENV=production bin/shakapacker --json public/webpack/production/webpack-stats.json
      - run:
          name: Download master branch stats
          command: yarn start bundleSize.download
      - run:
          name: Compare bundle sizes
          command: yarn start bundleSize.compare

  bundle-size-upload:
    <<: *defaults
    docker:
      - image: ekrueger88/printivity-ci:ruby-3.4.2--node-20.17.0
    steps:
      - checkout
      - restore_cache: *restore-gem-cache
      - restore_cache: *restore-yarn-cache
      - run: *enable-corepack
      - run: *add-node-module-path
      - run: *install-ruby-gems
      - run:
          name: Build production webpack assets
          command: RAILS_ENV=production NODE_ENV=production bin/shakapacker --json public/webpack/production/webpack-stats.json
      - run:
          name: Upload bundle size stats to S3
          command: yarn start bundleSize.upload

  build-experiment-ci-image:
    <<: *machine-defaults
    steps:
      - checkout
      - run:
          name: Build experiment Docker image
          command: |
            docker build -t printivity-experiment:${CIRCLE_SHA1} \
              -f ab-tests/docker/Dockerfile \
              --build-arg UID=$(id -u) \
              --build-arg GID=$(id -g) \
              --build-arg NON_ROOT_USER=$(whoami) \
              --build-arg HONEYBADGER_API_KEY=${STAGING_HONEYBADGER_API_KEY:-dummy-key} \
              --build-arg GIT_SHA=${CIRCLE_SHA1} \
              --build-arg HOST_URL=${STAGING_APP_HOST:-http://localhost:3000} \
              --build-arg SKIP_SOURCE_MAPS_TO_HONEYBADGER=true \
              --build-arg MGXCOPY_RECAPTCHA_SITE_KEY=${NON_TEST_RECAPTCHA_SITE_KEY:-dummy-key} \
              --build-arg ENABLE_ANALYTICS_TRACKING=false \
              --build-arg GTM_ID=dummy \
              --build-arg QZ_PRINT_PKEY=${QZ_PRINT_PKEY:-dummy} \
              --build-arg QZ_PRINT_CERT=${QZ_PRINT_CERT:-dummy} \
              .
            docker tag printivity-experiment:${CIRCLE_SHA1} printivity-experiment:latest
      - run:
          name: Save experiment Docker image
          command: |
            mkdir -p /tmp/docker-images
            docker save -o /tmp/docker-images/experiment.tar printivity-experiment:${CIRCLE_SHA1}
      - persist_to_workspace:
          root: /tmp
          paths:
            - docker-images/experiment.tar

  build-control-ci-image:
    <<: *machine-defaults
    steps:
      - checkout
      - run:
          name: Copy Dockerfile to temp location
          command: |
            mkdir -p /tmp/docker-build
            cp ab-tests/docker/Dockerfile /tmp/docker-build/
      - run:
          name: Checkout control (merge base with master)
          command: |
            mkdir -p /home/circleci/control_checkout
            git worktree add /home/circleci/control_checkout $(git merge-base HEAD origin/master)
      - run:
          name: Build control Docker image
          command: |
            # Copy the Dockerfile from current branch into the master checkout
            mkdir -p /home/circleci/control_checkout/ab-tests/docker
            cp /tmp/docker-build/Dockerfile /home/circleci/control_checkout/ab-tests/docker/
            cd /home/circleci/control_checkout
            docker build -t printivity-control:${CIRCLE_SHA1} \
              -f ab-tests/docker/Dockerfile \
              --build-arg UID=$(id -u) \
              --build-arg GID=$(id -g) \
              --build-arg NON_ROOT_USER=$(whoami) \
              --build-arg HONEYBADGER_API_KEY=${STAGING_HONEYBADGER_API_KEY:-dummy-key} \
              --build-arg GIT_SHA=${CIRCLE_SHA1} \
              --build-arg HOST_URL=${STAGING_APP_HOST:-http://localhost:3000} \
              --build-arg SKIP_SOURCE_MAPS_TO_HONEYBADGER=true \
              --build-arg MGXCOPY_RECAPTCHA_SITE_KEY=${NON_TEST_RECAPTCHA_SITE_KEY:-dummy-key} \
              --build-arg ENABLE_ANALYTICS_TRACKING=false \
              --build-arg GTM_ID=dummy \
              --build-arg QZ_PRINT_PKEY=${QZ_PRINT_PKEY:-dummy} \
              --build-arg QZ_PRINT_CERT=${QZ_PRINT_CERT:-dummy} \
              .
            docker tag printivity-control:${CIRCLE_SHA1} printivity-control:latest
      - run:
          name: Save control Docker image
          command: |
            mkdir -p /tmp/docker-images
            docker save -o /tmp/docker-images/control.tar printivity-control:${CIRCLE_SHA1}
      - persist_to_workspace:
          root: /tmp
          paths:
            - docker-images/control.tar

  prepare-twin-servers-workspace:
    <<: *machine-defaults
    steps:
      - checkout
      - run:
          name: Install Docker Compose
          command: |
            sudo curl -L "https://github.com/docker/compose/releases/download/v2.23.0/docker-compose-$(uname -s)-$(uname -m)" -o ~/docker-compose
            sudo chmod +x ~/docker-compose
            ~/docker-compose --version
      - run:
          name: Install dockerize
          command: |
            DOCKERIZE_VERSION=v0.6.1
            curl -sSL https://github.com/jwilder/dockerize/releases/download/$DOCKERIZE_VERSION/dockerize-linux-amd64-$DOCKERIZE_VERSION.tar.gz | sudo tar -xz -C ~
      - persist_to_workspace:
          root: ~/
          paths:
            - docker-compose
            - dockerize

  perf-tests:
    <<: *machine-defaults
    parallelism: 1
    environment:
      BASH_ENV: /home/circleci/.bashrc
    steps:
      - checkout
      - attach_workspace:
          at: /tmp/workspace
      - run:
          name: Set up environment variables and functions
          command: |
            echo "export CI_IMAGE_NAME=printivity-experiment:${CIRCLE_SHA1}" >> $BASH_ENV
            echo "export CI_CONTROL_IMAGE_NAME=printivity-control:${CIRCLE_SHA1}" >> $BASH_ENV
            source $BASH_ENV

            ab-tests/bin/define-helper-functions
      - run:
          name: Install bash dependencies
          command: |
            sudo mv /tmp/workspace/docker-compose /usr/local/bin/docker-compose
            docker-compose --version

            sudo mv /tmp/workspace/dockerize /usr/local/bin/dockerize
            dockerize --version

            sudo apt-get update
            sudo apt-get install parallel -y
            parallel --version
      - restore_cache: *restore-seeds-file-cache
      - run:
          name: Load Docker images
          command: |
            load_docker_image() {
              local image_name=$1
              docker load -i /tmp/workspace/docker-images/${image_name}.tar
            }
            export -f load_docker_image
            run_for_both_servers_in_parallel load_docker_image
      - run:
          name: Start twin containers
          command: |
            ab-tests/bin/start-containers
      - run:
          name: Run rails server (control)
          command: |
            run_cmd_in_control_container "bundle exec puma -C config/puma.rb -b tcp://0.0.0.0:3000"
          background: true
      - run:
          name: Run rails server (experiment)
          command: |
            run_cmd_in_experiment_container "bundle exec puma -C config/puma.rb -b tcp://0.0.0.0:3000"
          background: true
      - run:
          name: Run node renderer (control)
          command: |
            run_cmd_in_control_container "node node-renderer.js"
          background: true
      - run:
          name: Run node renderer (experiment)
          command: |
            run_cmd_in_experiment_container "node node-renderer.js"
          background: true
      - run:
          name: Wait for servers to boot
          command: |
            dockerize -wait http://localhost:3020 -timeout 30s
            dockerize -wait http://localhost:3030 -timeout 30s

parameters:
  # NOTE: When adding a new trigger on CircleCI, make sure to add `run-schedule` as a pipeline parameter,
  # with the value `true`, otherwise scheduled pipelines will not run.
  run-schedule:
    type: boolean
    default: false

workflows:
  version: 2

  # NOTE: Unscheduled workflows go here.
  #
  # Each unscheduled workflow must check that `run-schedule` is `false` before running, .e.g.:
  #   when:
  #     not: << pipeline.parameters.run-schedule >>

  review-app:
    when:
      not: << pipeline.parameters.run-schedule >>
    jobs:
      - start:
          filters:
            branches:
              ignore: master
          type: approval
      - build-review-app:
          filters:
            branches:
              ignore: master
          requires:
            - start
  storybook-review-app:
    when:
      not: << pipeline.parameters.run-schedule >>
    jobs:
      - start:
          filters:
            branches:
              ignore: master
          type: approval
      - build-storybook-review-app:
          filters:
            branches:
              ignore: master
          requires:
            - start

  test-suite:
    jobs:
      - install-production-ruby-gems
      - install-ruby-gems
      - install-node-packages
      - compile-webpack-assets:
          requires:
            - install-ruby-gems
            - install-node-packages
      - cypress-smarty-api-start:
          type: approval
      - eslint:
          requires:
            - install-node-packages
      - prettier:
          requires:
            - install-node-packages
      - scss-lint:
          requires:
            - install-ruby-gems
      - jest:
          requires:
            - install-node-packages
      - rspec:
          requires:
            - install-ruby-gems
            - install-node-packages
      - cypress:
          requires:
            - compile-webpack-assets
      - cypress-smarty-api-tests:
          requires:
            - compile-webpack-assets
            - cypress-smarty-api-start
      - rubocop:
          requires:
            - install-ruby-gems
      - security-checks:
          requires:
            - install-ruby-gems
      - bundle-size-check:
          requires:
            - install-ruby-gems
            - install-node-packages
          filters:
            branches:
              ignore: master
      - bundle-size-upload:
          requires:
            - install-ruby-gems
            - install-node-packages
          filters:
            branches:
              only: master
  release:
    when:
      not: << pipeline.parameters.run-schedule >>
    jobs:
      - deploy-to-production:
          filters:
            branches:
              only: master
          type: approval
      - controlplane-release-production:
          filters:
            branches:
              only: master
          requires:
            - deploy-to-production
      - controlplane-release-staging:
          filters:
            branches:
              only: master

  perf-test-twin-servers:
    when:
      not: << pipeline.parameters.run-schedule >>
    jobs:
      - approve-perf-tests:
          type: approval
          filters:
            branches:
              ignore: master
      - build-experiment-ci-image:
          requires:
            - approve-perf-tests
          filters:
            branches:
              ignore: master
          context: ab-tests
      - build-control-ci-image:
          requires:
            - approve-perf-tests
          filters:
            branches:
              ignore: master
          context: ab-tests
      - prepare-twin-servers-workspace:
          requires:
            - approve-perf-tests
          filters:
            branches:
              ignore: master
          context: ab-tests
      - perf-tests:
          requires:
            - build-experiment-ci-image
            - build-control-ci-image
            - prepare-twin-servers-workspace
          filters:
            branches:
              ignore: master
          context: ab-tests

  # NOTE: Scheduled workflows go here.
  #
  # Each scheduled workflow must check that `run-schedule` is `true` before running, .e.g.:
  #   when: << pipeline.parameters.run-schedule >>
  #
  # Additionally, you can check for a specific schedule:
  #   when:
  #     and:
  #       - << pipeline.parameters.run-schedule >>
  #       - equal: [name_of_schedule_you_want, << pipeline.schedule.name >>]
  nightly:
    when:
      and:
        - << pipeline.parameters.run-schedule >>
        - equal: [nightly, << pipeline.schedule.name >>]
    jobs:
      - nightly-cleanup-review-apps-and-staging-org:
          filters:
            branches:
              only: master
