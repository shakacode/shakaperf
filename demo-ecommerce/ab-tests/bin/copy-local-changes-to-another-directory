#!/bin/bash
# This command copies local changes to another directory.
# Usage: copy-local-changes-to-another-directory <path>

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib/colors.sh"
source "$SCRIPT_DIR/lib/ui.sh"
source "$SCRIPT_DIR/lib/git-utils.sh"

TARGET_DIR=$1

if [ -z "$TARGET_DIR" ]; then
  print_error "Usage: $0 <directory-path>"
  exit 1
fi

FILES=$(get_changed_files_with_deleted)

if [ -z "$FILES" ]; then
  print_warning "No changes to copy."
  exit 0
fi

DIRS=$(echo "$FILES" | extract_directories)

if [ -n "$DIRS" ]; then
  print_info "Creating directories in ${TARGET_DIR}..."
  while IFS= read -r dir; do
    mkdir -p "$TARGET_DIR/$dir"
  done <<< "$DIRS"
fi

print_info "Copying files to ${TARGET_DIR}..."
while IFS= read -r file; do
  cp -f "$file" "$TARGET_DIR/$file"
  echo "  Copied: $file"
done <<< "$FILES"

print_success "All files successfully copied to ${TARGET_DIR}!"

