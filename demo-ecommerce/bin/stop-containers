#!/bin/bash

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEMO_ECOMMERCE_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

cd "$DEMO_ECOMMERCE_DIR"

# Set default image names if not provided
export CI_IMAGE_NAME="${CI_IMAGE_NAME:-demo-ecommerce:experiment}"
export CI_CONTROL_IMAGE_NAME="${CI_CONTROL_IMAGE_NAME:-demo-ecommerce:control}"

echo "=========================================="
echo "Stopping Docker Containers"
echo "=========================================="
echo ""

# Stop servers first if they're running
echo "🛑 Stopping any running Rails servers..."
docker compose exec -T control-server bash -c "pkill -f 'rails server' || true" 2>/dev/null || true
docker compose exec -T experiment-server bash -c "pkill -f 'rails server' || true" 2>/dev/null || true

# Stop Overmind if it's running
if command -v overmind &> /dev/null && overmind ps &> /dev/null; then
  overmind quit || true
fi

echo "   ✓ Rails servers stopped"

echo ""
echo "🛑 Stopping Docker containers..."
docker compose down --remove-orphans
echo "   ✓ Containers stopped"

echo ""
echo "✅ All containers stopped!"
echo ""
echo "To start again:"
echo "  ./bin/start-containers"
echo ""
