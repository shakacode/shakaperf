{
  "id": "demo-ecommerce",
  "viewports": [
    {
      "label": "phone",
      "width": 375,
      "height": 667
    },
    {
      "label": "tablet",
      "width": 768,
      "height": 1024
    },
    {
      "label": "desktop",
      "width": 1280,
      "height": 800
    }
  ],
  "onBeforeScript": "playwright/onBefore.ts",
  "onReadyScript": "playwright/onReady.ts",
  "scenarios": [
    {
      "label": "Homepage",
      "url": "http://localhost:3030/",
      "referenceUrl": "http://localhost:3020/",
      "delay": 50,
      "misMatchThreshold": 0.01,
      "selectors": [
        "[data-cy='hero-section']",
        "[data-cy='features-section']",
        "document"
      ]
    },
    {
      "label": "Products List",
      "url": "http://localhost:3030/products",
      "referenceUrl": "http://localhost:3020/products",
      "delay": 50,
      "misMatchThreshold": 0.1
    },
    {
      "label": "Products - Electronics Filter",
      "url": "http://localhost:3030/products",
      "referenceUrl": "http://localhost:3020/products",
      "onReadyScript": "playwright/onReadyElectronicsFilter.ts",
      "delay": 50,
      "misMatchThreshold": 0.1
    },
    {
      "label": "Product Detail",
      "url": "http://localhost:3030/products/1",
      "referenceUrl": "http://localhost:3020/products/1",
      "delay": 50,
      "misMatchThreshold": 0.1
    },
    {
      "label": "Cart",
      "url": "http://localhost:3030/cart",
      "referenceUrl": "http://localhost:3020/cart",
      "delay": 50,
      "misMatchThreshold": 0.1
    },
    {
      "label": "Admin Dashboard - Cookie Login",
      "url": "http://localhost:3030/admin",
      "referenceUrl": "http://localhost:3020/admin",
      "cookiePath": "backstop_data/engine_scripts/admin-auth-cookie.json",
      "onReadyScript": "playwright/onReadyAdminWithCookie.ts",
      "delay": 50,
      "misMatchThreshold": 0.1
    },
    {
      "label": "Admin Orders - Form Login Interaction",
      "url": "http://localhost:3030/admin/orders",
      "referenceUrl": "http://localhost:3020/admin/orders",
      "onReadyScript": "playwright/onReadyAdminWithInteraction.ts",
      "delay": 50,
      "misMatchThreshold": 0.1
    },
    {
      "label": "Carousel Demo - Pause With Override CSS",
      "url": "http://localhost:3030/carousel-demo",
      "referenceUrl": "http://localhost:3020/carousel-demo",
      "onReadyScript": "playwright/onReadyCarouselPaused.ts",
      "delay": 50,
      "misMatchThreshold": 0.1
    },
    {
      "label": "Carousel Demo - Stub Slider Images",
      "url": "http://localhost:3030/carousel-demo",
      "referenceUrl": "http://localhost:3020/carousel-demo",
      "onReadyScript": "playwright/onReadyCarouselStubImages.ts",
      "delay": 50,
      "misMatchThreshold": 0.1
    }
  ],
  "paths": {
    "bitmaps_reference": "backstop_data/bitmaps_reference",
    "bitmaps_test": "backstop_data/bitmaps_test",
    "engine_scripts": "backstop_data/engine_scripts",
    "html_report": "backstop_data/html_report",
    "ci_report": "backstop_data/ci_report"
  },
  "report": [
    "browser",
    "CI"
  ],
  "engineOptions": {
    "browser": "chromium",
    "args": [
      "--no-sandbox"
    ]
  },
  "asyncCaptureLimit": 5,
  "compareRetries": 5,
  "compareRetryDelay": 1000,
  "maxNumDiffPixels": 50,
  "asyncCompareLimit": 50,
  "debug": false,
  "debugWindow": false
}