#!/bin/bash

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib/ui.sh"
source "$SCRIPT_DIR/lib/validation.sh"
source "$SCRIPT_DIR/define-helper-functions"

print_banner "Starting Twin Servers Locally"

ensure_project_root

echo "📝 Using images:"
echo "  - Experiment: $CI_IMAGE_NAME"
echo "  - Control: $CI_CONTROL_IMAGE_NAME"
echo ""

require_docker_image "$CI_IMAGE_NAME"
require_docker_image "$CI_CONTROL_IMAGE_NAME"

echo "🛑 Stopping any existing twin servers..."
ab-tests/bin/stop || true

echo "🚀 Starting twin servers..."
twin_servers_compose up -d --remove-orphans

echo "⏳ Waiting for services to initialize..."
sleep 5

echo "📊 Checking service status..."
twin_servers_compose ps

echo ""
echo "🔍 Checking MySQL status (control)..."
twin_servers_compose logs mysql-control | tail -10

echo ""
echo "🔍 Checking MySQL status (experiment)..."
twin_servers_compose logs mysql-experiment | tail -10

echo ""
echo "🔍 Checking Redis status..."
twin_servers_compose logs redis | tail -10

echo ""
echo "⏳ Waiting for containers to start..."
wait_for_container control-server
wait_for_container experiment-server

if [ -z "$CI" ]; then
  bin/rake seeding:download_versioned_seed[./seeds_cache]
fi

setup_database_for_server() {
  local server_type=$1
  run_cmd_in_container "$server_type-server" "CONFIGURING_DATABASE=1 bin/rails db:create"
  run_cmd_in_container "$server_type-server" "CONFIGURING_DATABASE=1 bin/rails db:schema:load"
  if [ -d ./seeds_cache ]; then
    cp ./seeds_cache/* ~/printivity_${server_type}_docker_volume/db/seeds/
  fi
  run_cmd_in_container "$server_type-server" "bin/rails db:seed"
  run_cmd_in_container "$server_type-server" "bin/rails db:migrate"
}
export -f setup_database_for_server
export -f run_cmd_in_container
export -f twin_servers_compose

echo ""
echo "Importing databases"

run_for_both_servers_in_parallel setup_database_for_server

echo ""
print_success "🎉 Both servers are healthy!"
echo ""
print_banner "There are no servers yet, but the following ports are occupied:"
echo "Control Server:    http://localhost:3020"
echo "Experiment Server: http://localhost:3030"
echo -e "You can free these ports by stopping the twin containers with: ${RED}ab-tests/bin/stop${NO_COLOR}"
echo "=========================================="
echo ""
echo "Next steps:"
echo -e "1. Start twin servers: ${BLUE}ab-tests/bin/start-servers${NO_COLOR}"
echo -e "2. To debug, run: ${BLUE}source ab-tests/bin/define-helper-functions${NO_COLOR}"
echo -e "    and then run: ${BLUE}run_cmd_in_experiment_container bash${NO_COLOR}"
echo -e "    or run: ${BLUE}run_cmd_in_control_container bash${NO_COLOR}"
echo "3. Edit project code inside containers:"
echo -e "    - ${BLUE}~/printivity_experiment_docker_volume/${NO_COLOR} for experiment"
echo -e "    - ${BLUE}~/printivity_control_docker_volume/${NO_COLOR} for control"
echo "4. Or you can copy local changes to the containers using:"
echo -e "    - ${BLUE}ab-tests/bin/copy-local-changes-to-another-directory ~/printivity_experiment_docker_volume/ ${NO_COLOR}"
echo -e "    - ${BLUE}ab-tests/bin/copy-local-changes-to-another-directory ~/printivity_control_docker_volume/ ${NO_COLOR}"
exit 0
