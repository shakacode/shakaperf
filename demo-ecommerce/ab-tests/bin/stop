#!/bin/bash

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib/ui.sh"
source "$SCRIPT_DIR/define-helper-functions"

twin_servers_compose down

docker volume rm docker_printivity_experiment docker_printivity_control || true
rm -rf ~/printivity_experiment_docker_volume ~/printivity_control_docker_volume || true
mkdir -p ~/printivity_experiment_docker_volume 
mkdir -p ~/printivity_control_docker_volume

print_success "Twin servers stopped successfully!"

