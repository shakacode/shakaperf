#!/bin/bash

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEMO_ECOMMERCE_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

cd "$DEMO_ECOMMERCE_DIR"

source "$SCRIPT_DIR/define-helper-functions"

# Parse arguments
server_type="${1:-both}"
rebuild_type="${2:-assets}"

print_banner "Rebuilding $server_type Server(s)"

ensure_project_root

# Validate server type
if [ "$server_type" != "experiment" ] && [ "$server_type" != "control" ] && [ "$server_type" != "both" ]; then
  print_error "Invalid server type: $server_type"
  echo "Must be 'experiment', 'control', or 'both'"
  exit 1
fi

# Function to rebuild assets in a server
rebuild_assets() {
  local server="$1"
  print_info "Recompiling assets in $server-server..."
  run_cmd_in_container "$server-server" "RAILS_ENV=production NODE_ENV=production bundle exec rails assets:precompile"
}

# Function to reinstall gems in a server
rebuild_gems() {
  local server="$1"
  print_info "Reinstalling gems in $server-server..."
  run_cmd_in_container "$server-server" "bundle install"
}

# Function to reinstall yarn packages in a server
rebuild_yarn() {
  local server="$1"
  print_info "Reinstalling yarn packages in $server-server..."
  run_cmd_in_container "$server-server" "yarn install"
}

# Function to do full rebuild
rebuild_full() {
  local server="$1"
  print_info "Full rebuild for $server-server..."
  rebuild_yarn "$server"
  rebuild_gems "$server"
  rebuild_assets "$server"
}

# Execute rebuild based on type
do_rebuild() {
  local server="$1"

  case "$rebuild_type" in
    assets)
      rebuild_assets "$server"
      ;;
    gems)
      rebuild_gems "$server"
      ;;
    yarn)
      rebuild_yarn "$server"
      ;;
    full)
      rebuild_full "$server"
      ;;
    *)
      print_error "Invalid rebuild type: $rebuild_type"
      echo "Must be 'assets', 'gems', 'yarn', or 'full'"
      exit 1
      ;;
  esac
}

# Rebuild servers
if [ "$server_type" = "both" ]; then
  do_rebuild "control"
  echo ""
  do_rebuild "experiment"
else
  do_rebuild "$server_type"
fi

echo ""
print_success "Rebuild complete!"
echo ""
echo "Next steps:"
echo "  1. Restart affected servers with Overmind:"
if [ "$server_type" = "both" ]; then
  echo "     overmind restart control-rails"
  echo "     overmind restart experiment-rails"
else
  echo "     overmind restart ${server_type}-rails"
fi
echo ""
echo "  2. Or restart everything:"
echo "     ./bin/stop && ./bin/start-containers && ./bin/start-servers"
echo ""
echo "Usage: bin/rebuild [experiment|control|both] [assets|gems|yarn|full]"
echo "  Default: both assets"
