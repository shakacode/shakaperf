#!/bin/bash

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib/ui.sh"
source "$SCRIPT_DIR/lib/validation.sh"
source "$SCRIPT_DIR/define-helper-functions"

# Validate argument
if [ -z "$1" ]; then
  print_error "Usage: ab-tests/bin/compile-assets <experiment|control>"
  exit 1
fi

server_type="$1"

if [ "$server_type" != "experiment" ] && [ "$server_type" != "control" ]; then
  print_error "Invalid server type: $server_type"
  echo "Must be 'experiment' or 'control'"
  exit 1
fi

print_banner "Compiling Assets for ${server_type^} Server"

ensure_project_root

print_info "Compiling assets inside $server_type-server container..."

run_cmd_in_container "$server_type-server" "RAILS_ENV=production NODE_ENV=production bundle exec rails assets:precompile"

echo ""
print_success "Assets compiled successfully for $server_type server!"
