#!/bin/bash

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib/ui.sh"
source "$SCRIPT_DIR/lib/validation.sh"
source "$SCRIPT_DIR/define-helper-functions"

print_banner "Building Twin Servers Docker Images"

ensure_project_root
require_command "parallel" "brew install parallel (Mac) or sudo apt-get install parallel (Linux)"
require_directory "../printivity_control" "To set up the control directory:
  1. Copy the current directory to create the control:
     cp -r $(pwd) ../printivity_control

  2. Checkout a proper baseline (e.g., master branch):
     cd ../printivity_control
     git checkout master

The control directory serves as the baseline for A/B testing."

# Set environment variables (using dummy values for local testing)
export GIT_SHA="${GIT_SHA:-$(git rev-parse --short HEAD)}"
export HOST_URL="http://localhost:3000"
export SKIP_SOURCE_MAPS_TO_HONEYBADGER="true"
export MGXCOPY_RECAPTCHA_SITE_KEY="dummy-key-for-local-testing"
export ENABLE_ANALYTICS_TRACKING="false"
export GTM_ID="dummy"
export QZ_PRINT_PKEY="dummy"
export QZ_PRINT_CERT="dummy"

print_info "🏗️  Building both Docker images in parallel..."
echo ""

# Unified build function for both experiment and control
# Parameters: server_type (experiment|control)
build_server() {
  local server_type=$1
  local image_name="printivity-${server_type}"
  local build_dir="."
  local git_sha="${GIT_SHA}"
  
  if [ "$server_type" = "control" ]; then
    build_dir="../printivity_control"
    git_sha=$(cd "$build_dir" && git rev-parse --short HEAD)
  fi
  
  (
    cd "$build_dir"
    docker build -t "$image_name" \
      -f ab-tests/docker/Dockerfile \
      --build-arg UID=$(id -u) \
      --build-arg GID=$(id -g) \
      --build-arg NON_ROOT_USER=$(whoami) \
      --build-arg GH_NPM_TOKEN="${GH_NPM_TOKEN}" \
      --build-arg GIT_SHA="${git_sha}" \
      --build-arg HOST_URL="${HOST_URL}" \
      --build-arg SKIP_SOURCE_MAPS_TO_HONEYBADGER="${SKIP_SOURCE_MAPS_TO_HONEYBADGER}" \
      --build-arg MGXCOPY_RECAPTCHA_SITE_KEY="${MGXCOPY_RECAPTCHA_SITE_KEY}" \
      --build-arg ENABLE_ANALYTICS_TRACKING="${ENABLE_ANALYTICS_TRACKING}" \
      --build-arg GTM_ID="${GTM_ID}" \
      --build-arg QZ_PRINT_PKEY="${QZ_PRINT_PKEY}" \
      --build-arg QZ_PRINT_CERT="${QZ_PRINT_CERT}" \
      .
  )
}

export -f build_server

run_for_both_servers_in_parallel build_server

echo ""
print_success "Docker images built successfully!"
echo ""
echo "Images created:"
echo "  - printivity-experiment (current branch)"
echo "  - printivity-control (master branch from ../printivity_control)"
echo ""
echo -e "Next step: Run ${GREEN}ab-tests/bin/start-containers${NO_COLOR}"

