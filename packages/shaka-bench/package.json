{
  "name": "shaka-bench",
  "version": "0.0.3",
  "description": "Benchmarking tools for web applications",
  "main": "dist/cli/index.js",
  "types": "dist/cli/index.d.ts",
  "bin": "./dist/cli/cli.js",
  "files": [
    "dist",
    "tb-schema.json"
  ],
  "scripts": {
    "build": "cp -r ../../shared src/shared && tsc && cp -a ./src/cli/static ./dist/cli",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "yarn build"
  },
  "keywords": [
    "benchmark",
    "performance",
    "react",
    "testing"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shakacode/shakaperf.git",
    "directory": "packages/shaka-bench"
  },
  "homepage": "https://github.com/shakacode/shakaperf#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "chalk": "^4.1.1",
    "chrome-launcher": "^0.15.1",
    "cli-table3": "^0.6.0",
    "commander": "^13.1.0",
    "d3-array": "~2.12.1",
    "d3-hierarchy": "^3.0.1",
    "d3-scale": "~3.3.0",
    "debug": "^4.3.1",
    "fs-extra": "^10.0.0",
    "handlebars": "^4.7.7",
    "html-minifier-terser": "^7.0.0",
    "json5": "^2.2.0",
    "jstat": "^1.9.5",
    "lighthouse": "12.3.0",
    "race-cancellation": "^0.4.1",
    "tslib": "^2.2.0"
  },
  "devDependencies": {
    "@types/d3-array": "~2.12.1",
    "@types/d3-hierarchy": "^3.1.0",
    "@types/d3-scale": "~3.0.0",
    "@types/debug": "^4.1.7",
    "@types/fs-extra": "^9.0.11",
    "@types/html-minifier-terser": "^7.0.0",
    "@types/json5": "^2.2.0",
    "typescript": "^5.3.3"
  }
}
