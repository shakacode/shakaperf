{
  "name": "shaka-bench",
  "version": "0.0.2",
  "description": "Benchmarking tools for React and React on Rails apps",
  "main": "dist/cli/index.js",
  "types": "dist/cli/index.d.ts",
  "bin": "./bin/run",
  "files": [
    "bin",
    "dist",
    "tb-schema.json"
  ],
  "scripts": {
    "build": "tsc && cp -a ./src/cli/static ./dist/cli",
    "prepublishOnly": "yarn build"
  },
  "keywords": [
    "benchmark",
    "performance",
    "react",
    "testing"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shakacode/shaka-perf.git",
    "directory": "packages/shaka-bench"
  },
  "homepage": "https://github.com/shakacode/shaka-perf#readme",
  "publishConfig": {
    "access": "public"
  },
  "oclif": {
    "commands": "./dist/cli/commands",
    "bin": "shaka-bench",
    "plugins": [
      "@oclif/plugin-help"
    ]
  },
  "dependencies": {
    "@oclif/command": "^1.8.0",
    "@oclif/config": "^1.18.3",
    "@oclif/errors": "^1.3.5",
    "@oclif/help": "^1.0.15",
    "@oclif/parser": "^3.8.5",
    "@oclif/plugin-help": "^5.1.11",
    "archiver": "^5.3.0",
    "array-binsearch": "^1.0.1",
    "chalk": "^4.1.1",
    "chrome-debugging-client": "2.0.0",
    "chrome-launcher": "^0.15.1",
    "cli-table3": "^0.6.0",
    "d3-array": "~2.12.1",
    "d3-hierarchy": "^3.0.1",
    "d3-scale": "~3.3.0",
    "debug": "^4.3.1",
    "devtools-protocol": "^0.0.975963",
    "execa": "^6.1.0",
    "fs-extra": "^10.0.0",
    "handlebars": "^4.7.7",
    "html-minifier-terser": "^7.0.0",
    "json-query": "^2.2.2",
    "json5": "^2.2.0",
    "jstat": "^1.9.5",
    "lighthouse": "12.3.0",
    "listr": "^0.14.3",
    "lodash.clonedeep": "^4.5.0",
    "mime-types": "^2.1.35",
    "race-cancellation": "^0.4.1",
    "silent-error": "^1.1.1",
    "tmp": "^0.2.1",
    "tough-cookie": "^4.0.0",
    "tslib": "^2.2.0"
  },
  "devDependencies": {
    "@types/d3-array": "~2.12.1",
    "@types/d3-hierarchy": "^3.1.0",
    "@types/d3-scale": "~3.0.0",
    "@types/debug": "^4.1.7",
    "@types/fs-extra": "^9.0.11",
    "@types/html-minifier-terser": "^7.0.0",
    "@types/json-query": "^2.2.0",
    "@types/json5": "^2.2.0",
    "@types/listr": "^0.14.4",
    "@types/mime-types": "^2.1.1",
    "@types/tmp": "^0.2.0",
    "typescript": "^5.3.3"
  }
}
