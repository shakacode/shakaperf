{
  "name": "shaka-perf",
  "version": "0.0.0",
  "private": true,
  "description": "Performance tools monorepo for React and React on Rails apps",
  "workspaces": [
    "packages/*",
    "demo-ecommerce"
  ],
  "scripts": {
    "build": "yarn workspaces foreach -A --include 'packages/*' run build",
    "test:integration": "yarn playwright test -c playwright.integration.config.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/shakacode/shaka-perf.git"
  },
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "typescript": "^5.3.3"
  },
  "packageManager": "yarn@4.12.0",
  "resolutions": {
    "@tracerbench/find-chrome": "2.0.0"
  }
}
