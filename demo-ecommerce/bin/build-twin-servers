#!/bin/bash

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEMO_ECOMMERCE_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
MONOREPO_ROOT="$(cd "$DEMO_ECOMMERCE_DIR/.." && pwd)"

# Source helper functions if they exist
if [ -f "$DEMO_ECOMMERCE_DIR/ab-tests/bin/lib/ui.sh" ]; then
  source "$DEMO_ECOMMERCE_DIR/ab-tests/bin/lib/ui.sh"
  source "$DEMO_ECOMMERCE_DIR/ab-tests/bin/lib/validation.sh"
  print_banner "Building Twin Servers Docker Images"
else
  # Fallback if lib doesn't exist
  echo "=========================================="
  echo "Building Twin Servers Docker Images"
  echo "=========================================="
  echo ""
fi

# Ensure we're in the monorepo root
cd "$MONOREPO_ROOT"

# Check for required command
if ! command -v parallel &> /dev/null; then
  echo "❌ Error: 'parallel' command not found"
  echo "Install with: brew install parallel (Mac) or sudo apt-get install parallel (Linux)"
  exit 1
fi

# Check for control directory
CONTROL_DIR="$(dirname "$MONOREPO_ROOT")/shaka-perf-control"
if [ ! -d "$CONTROL_DIR" ]; then
  echo "❌ Error: Control directory not found at $CONTROL_DIR"
  echo ""
  echo "To set up the control directory:"
  echo "  1. Clone the monorepo to create the control:"
  echo "     cd $(dirname "$MONOREPO_ROOT")"
  echo "     git clone <repo-url> shaka-perf-control"
  echo ""
  echo "  2. Checkout the baseline branch (e.g., main):"
  echo "     cd shaka-perf-control"
  echo "     git checkout main"
  echo ""
  echo "The control directory serves as the baseline for A/B testing."
  exit 1
fi

# Create bind-mount directories
CONTROL_VOLUME_DIR="$HOME/demo_ecommerce_control_docker_volume"
EXPERIMENT_VOLUME_DIR="$HOME/demo_ecommerce_experiment_docker_volume"

echo "📁 Creating bind-mount directories..."
mkdir -p "$CONTROL_VOLUME_DIR"
mkdir -p "$EXPERIMENT_VOLUME_DIR"
echo "   ✓ $CONTROL_VOLUME_DIR"
echo "   ✓ $EXPERIMENT_VOLUME_DIR"
echo ""

# Set environment variables (using dummy values for local testing)
export GIT_SHA="${GIT_SHA:-$(git rev-parse --short HEAD)}"
export RAILS_MASTER_KEY="${RAILS_MASTER_KEY:-dummy-key-for-local-testing}"

echo "🏗️  Building both Docker images in parallel..."
echo ""

# Unified build function for both experiment and control
# Parameters: server_type (experiment|control)
build_server() {
  local server_type=$1
  local image_name="demo-ecommerce:${server_type}"
  local build_dir="$MONOREPO_ROOT"
  local git_sha="$GIT_SHA"

  if [ "$server_type" = "control" ]; then
    build_dir="$CONTROL_DIR"
    git_sha=$(cd "$build_dir" && git rev-parse --short HEAD)
  fi

  echo "Building ${server_type} from ${build_dir}..."

  (
    cd "$build_dir"
    docker build -t "$image_name" \
      -f demo-ecommerce/Dockerfile.production \
      --build-arg UID=$(id -u) \
      --build-arg GID=$(id -g) \
      --build-arg NON_ROOT_USER=$(whoami) \
      --build-arg RUBY_VERSION=3.3.7 \
      --build-arg NODE_VERSION=20 \
      .
  )

  echo "✓ Finished building ${server_type}"
}

export -f build_server
export MONOREPO_ROOT
export CONTROL_DIR
export GIT_SHA

# Build in parallel
parallel -j 2 build_server ::: experiment control

echo ""
echo "✅ Docker images built successfully!"
echo ""
echo "Images created:"
echo "  - demo-ecommerce:experiment (current branch: $(cd "$MONOREPO_ROOT" && git branch --show-current))"
echo "  - demo-ecommerce:control (baseline branch: $(cd "$CONTROL_DIR" && git branch --show-current))"
echo ""
echo "Bind-mount directories:"
echo "  - Control: $CONTROL_VOLUME_DIR"
echo "  - Experiment: $EXPERIMENT_VOLUME_DIR"
echo ""
echo "Next steps:"
echo "  1. Export environment variables:"
echo "     export RAILS_MASTER_KEY=\$(cat demo-ecommerce/config/master.key)"
echo "     export CI_IMAGE_NAME=demo-ecommerce:experiment"
echo "     export CI_CONTROL_IMAGE_NAME=demo-ecommerce:control"
echo ""
echo "  2. Start the containers:"
echo "     cd demo-ecommerce && docker compose up"
echo ""
