#!/bin/bash
# Convenience script that stops everything (servers + containers)

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

echo "=========================================="
echo "Stopping Twin Servers (All)"
echo "=========================================="
echo ""

# Stop servers first, then containers
"$SCRIPT_DIR/stop-servers"
echo ""
"$SCRIPT_DIR/stop-containers"
