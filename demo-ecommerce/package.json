{
  "packageManager": "yarn@4.12.0",
  "name": "demo-ecommerce",
  "private": true,
  "version": "0.1.0",
  "browserslist": [
    "defaults"
  ],
  "scripts": {
    "build": "bin/shakapacker",
    "build:prod": "NODE_OPTIONS='--max-old-space-size=4096' NODE_ENV=production bin/shakapacker --bundler rspack",
    "build:prod:stats": "CLIENT_BUNDLE_ONLY=true yarn build:prod --json public/packs/${BUNDLE_NAME:-app}-webpack-stats.json",
    "build:prod:consumer": "BUNDLE_NAME=consumer yarn build:prod:stats",
    "build:prod:admin": "BUNDLE_NAME=admin ADMIN_BUNDLE_ONLY=true yarn build:prod:stats",
    "build:prod:all:stats": "yarn build:prod:consumer && yarn build:prod:admin",
    "build:analyze": "ANALYZE=true bin/shakapacker",
    "bundle-size:download": "shaka-bundle-size download-main-branch-stats && shaka-bundle-size -c admin.bundle-size.config.ts download-main-branch-stats",
    "bundle-size:compare": "shaka-bundle-size generate-stats && shaka-bundle-size compare && shaka-bundle-size -c admin.bundle-size.config.ts generate-stats && shaka-bundle-size -c admin.bundle-size.config.ts compare",
    "bundle-size:upload": "shaka-bundle-size generate-stats && shaka-bundle-size upload-main-branch-stats && shaka-bundle-size -c admin.bundle-size.config.ts generate-stats && shaka-bundle-size -c admin.bundle-size.config.ts upload-main-branch-stats",
    "typecheck": "tsc --noEmit",
    "compare": "shaka-perf compare",
    "rebuild-deps": "yarn workspaces foreach -Apt --include 'packages/*' run build && yarn install"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@loadable/component": "^5.16.7",
    "@loadable/server": "^5.16.7",
    "@mui/icons-material": "^7.3.7",
    "@mui/material": "^7.3.7",
    "@rspack/core": "^1.3.12",
    "css-loader": "7.1.2",
    "prop-types": "15.8.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-on-rails": "16.2.0-rc.0",
    "react-router-dom": "^7.12.0",
    "rspack-manifest-plugin": "^5.2.1",
    "sass-loader": "^16.0.6",
    "shakapacker": "9.5.0",
    "style-loader": "4.0.0"
  },
  "devDependencies": {
    "@loadable/webpack-plugin": "^5.15.2",
    "@rspack/cli": "^1.3.12",
    "@rspack/plugin-react-refresh": "^1.3.12",
    "@swc/plugin-loadable-components": "10.0.0",
    "@types/loadable__component": "^5.13.10",
    "@types/loadable__server": "^5.12.11",
    "@types/loadable__webpack-plugin": "^5",
    "@types/node": "24",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.23",
    "compression-webpack-plugin": "^11.1.0",
    "playwright-core": "^1.52.0",
    "postcss": "^8.5.6",
    "react-refresh": "0.18.0",
    "shaka-bundle-size": "workspace:*",
    "shaka-perf": "workspace:*",
    "shaka-shared": "workspace:^",
    "typescript": "^5.9.3",
    "webpack-bundle-analyzer": "^5.1.1"
  }
}
