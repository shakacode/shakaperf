  "homepage": "https://github.com/shakacode/shakaperf#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "dotenv": "^16.0.0",
    "tsx": "^4.21.0",
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "shaka-bundle-size": "*"
  },
  "peerDependenciesMeta": {
    "shaka-bundle-size": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
