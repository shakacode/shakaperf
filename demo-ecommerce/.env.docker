# Docker environment variables for local production testing
#
# Usage:
#   1. Copy this file: cp .env.docker .env.docker.local
#   2. Run: docker compose --env-file .env.docker.local up --build
#
# Note: SECRET_KEY_BASE is already set in docker-compose.yml for the demo app.
# No master key or credentials setup needed.

# Optional: Override defaults if needed
# RAILS_ENV=production
# RAILS_SERVE_STATIC_FILES=true
# DISABLE_SSL=true
